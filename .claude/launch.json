{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "hepatoguard-backend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd backend && source .venv/bin/activate && uvicorn app.main:app --host 0.0.0.0 --port 8000"],
      "port": 8000
    },
    {
      "name": "hepatoguard-frontend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd frontend && npm run dev"],
      "port": 3000
    }
  ]
}
